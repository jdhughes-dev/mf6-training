# codespell configuration (also read by the codespell pre-commit hook).
# https://github.com/codespell-project/codespell
[codespell]
# Don't spell-check generated / non-prose files.
skip = .git,.pixi,pixi.lock,*.lock,*.svg,*.png,*.jpg,*.pdf,examples/data
# Ignore long base64 runs (e.g. image attachments embedded in notebook cells),
# which otherwise produce false positives. No real word/identifier is this long.
ignore-regex = [A-Za-z0-9+/=]{50,}
# Comma-separated, lowercase list of words to treat as correct - MODFLOW domain
# terms / package acronyms that codespell mistakes for typos (e.g. wel -> well).
ignore-words-list = nam,wel,delt
