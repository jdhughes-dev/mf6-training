# Normalize all text files to LF in the repository and on checkout, so
# committed line endings are always Unix-style (linux/mac) regardless of the
# platform or git settings of whoever commits.
* text=auto eol=lf

# Batch files need CRLF in the working tree to run reliably on Windows.
# They are still stored as LF in the repository.
*.bat text eol=crlf

# MODFLOW/MODPATH binary output must never be treated as text. The `text=auto`
# rule above can misdetect a binary file as text and normalize its bytes on
# checkout/commit, corrupting it -- this is what mangled the committed
# ex-gwe-prt-gwf.disv.grb (one stray byte) and broke prt-voronoi. Mark the
# binary file types explicitly so git stores/checks them out verbatim.
*.grb binary
*.hds binary
*.cbc binary
*.cbb binary
*.bud binary
*.ucn binary
*.bin binary
*.nc binary
